+  /**
+   * Obturador curto (~1/1700 s) via Camera2, para reduzir desfoque por movimento/trepidação.
+   * Só aplica com flash desligado; com flash, o [ImageCapture] padrão costuma ser necessário para o sync do disparo.
+   */
+  @OptIn(ExperimentalCamera2Interop::class)
+  private fun createStillImageCaptureWithFastShutter(
+    resolutionSelector: ResolutionSelector
+  ): ImageCapture {
+    val builder = ImageCapture.Builder()
+      .setResolutionSelector(resolutionSelector)
+      .setFlashMode(flashMode.mapToLens())
+    val ext = Camera2Interop.Extender(builder)
+    val exposureNs = 1_000_000_000L / 1700
+    val iso = 1000
+    ext.setCaptureRequestOption(CaptureRequest.CONTROL_AE_MODE, CaptureRequest.CONTROL_AE_MODE_OFF)
+    ext.setCaptureRequestOption(CaptureRequest.SENSOR_EXPOSURE_TIME, exposureNs)
+    ext.setCaptureRequestOption(CaptureRequest.SENSOR_SENSITIVITY, iso)
+    val frameNs = (exposureNs * 2).coerceAtLeast(1_000_000L)
+    ext.setCaptureRequestOption(CaptureRequest.SENSOR_FRAME_DURATION, frameNs)
+    return builder.build()
+  }
